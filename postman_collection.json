    {
      "name": "🔌 Session Management",
      "item": [
        {
          "name": "Create SSE Session",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Очистить старый session_id перед новым запросом",
                  "pm.environment.set('session_id', 'PENDING');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is text/event-stream', function() {",
                  "  pm.expect(pm.response.headers.get('content-type')).to.include('text/event-stream');",
                  "});",
                  "",
                  "// Парсим SSE ответ",
                  "var responseText = pm.response.text();",
                  "console.log('Response length: ' + responseText.length);",
                  "",
                  "// Ищем data линию с sessionId",
                  "var sessionId = null;",
                  "var lines = responseText.split('\\n');",
                  "",
                  "for (var i = 0; i < lines.length; i++) {",
                  "  var line = lines[i].trim();",
                  "  if (line.startsWith('data: ')) {",
                  "    try {",
                  "      var jsonStr = line.substring(6).trim();",
                  "      if (jsonStr) {",
                  "        var data = JSON.parse(jsonStr);",
                  "        if (data.result && data.result.sessionId) {",
                  "          sessionId = data.result.sessionId;",
                  "          console.log('✓ Session ID найден: ' + sessionId);",
                  "          break;",
                  "        }",
                  "      }",
                  "    } catch(e) {",
                  "      console.log('Parsing error at line ' + i + ': ' + e);",
                  "    }",
                  "  }",
                  "}",
                  "",
                  "pm.test('Session ID successfully extracted', function() {",
                  "  pm.expect(sessionId).to.not.be.null;",
                  "  pm.expect(sessionId).to.be.a('string');",
                  "  pm.expect(sessionId.length).to.be.above(5);",
                  "});",
                  "",
                  "// Сохранить в environment переменную",
                  "if (sessionId) {",
                  "  pm.environment.set('session_id', sessionId);",
                  "  pm.globals.set('session_id', sessionId); // также в глобальные",
                  "  console.log('✓ Session ID сохранен в environment');",
                  "}",
                  "",
                  "// Опционально: сохранить время создания",
                  "pm.environment.set('session_created_at', new Date().toISOString());"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "text/event-stream"
              }
            ],
            "url": {
              "raw": "{{host}}/sse",
              "host": ["{{host}}"],
              "path": ["sse"]
            }
          },
          "response": []
        }
      ]
    },
