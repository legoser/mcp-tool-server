# MCP Server
HOST=0.0.0.0
PORT=3344
TRANSPORT=http
FASTMCP_STATELESS_HTTP=true
CLIENT_TOKEN=
CLIENT_BASE_URL=http://localhost:3344

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# HTTP client settings
HTTP_TIMEOUT=30.0
HTTP_VERIFY_SSL=true

# Rate limiting (requests per minute)
SEARCH_RATE_LIMIT=30
WEB_FETCH_RATE_LIMIT=20
WEATHER_RATE_LIMIT=30

# Ollama / LLM settings
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
LLM_MODEL_NAME=qwen2.5-coder:7b

# Search Providers
BRAVE_API_KEY=

# Weather API (Open-Meteo - free, no key required)
WEATHER_API_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
WEATHER_API_FORECAST_URL=https://api.open-meteo.com/v1/forecast

# Web fetch settings
WEB_FETCH_MAX_LENGTH=8000
